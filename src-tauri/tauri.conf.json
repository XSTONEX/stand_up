{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stand UP",
  "version": "0.2.0",
  "identifier": "com.kaidaocea.standup",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Stand UP!",
        "width": 360,
        "height": 443,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "windowEffects": {
          "effects": ["popover", "sidebar"],
          "radius": 22,
          "state": "active"
        }
      },
      {
        "label": "popover",
        "url": "popover.html",
        "title": "Stand UP!",
        "width": 360,
        "height": 238,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["popover", "sidebar"],
          "radius": 22,
          "state": "active"
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/XSTONEX/stand_up/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBNzA0QTE3OEExMTNEQjQKUldTMFBSR0tGMHB3cWdhRUtyb2hheFRCM0haN015aldYenFNYnd6em5vTmN4RXliKzBSTTUwN0kK"
    }
  }
}
