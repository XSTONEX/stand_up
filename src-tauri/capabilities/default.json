{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Stand UP windows",
  "windows": ["main", "popover"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging"
  ]
}
